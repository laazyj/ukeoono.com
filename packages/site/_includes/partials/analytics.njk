{% if analytics.measurementId %}
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag() { dataLayer.push(arguments); }
  gtag("consent", "default", {
    ad_storage: "denied",
    ad_user_data: "denied",
    ad_personalization: "denied",
    analytics_storage: "denied",
    wait_for_update: 500,
  });
  try {
    if (localStorage.getItem("ukeoono-consent-v1") === "granted") {
      gtag("consent", "update", { analytics_storage: "granted" });
    }
  } catch (e) {}
  gtag("js", new Date());
  gtag("config", "{{ analytics.measurementId }}", { anonymize_ip: true });
</script>
<script async src="https://www.googletagmanager.com/gtag/js?id={{ analytics.measurementId }}"></script>
{% endif %}
