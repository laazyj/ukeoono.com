{
  "name": "@uke-o-ono/site",
  "version": "0.0.0",
  "private": true,
  "description": "Single-page Fringe 2026 flyer for uke-o-ono.com (Eleventy).",
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "eleventy",
    "start": "eleventy --serve --quiet"
  },
  "nx": {
    "targets": {
      "build": {
        "inputs": [
          "default",
          "^default",
          {
            "env": "GA_MEASUREMENT_ID"
          },
          {
            "env": "GITHUB_SHA"
          }
        ]
      },
      "start": {
        "cache": false
      }
    }
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.6"
  }
}
